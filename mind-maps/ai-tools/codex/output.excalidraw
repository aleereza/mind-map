      "link": null,
      "locked": false,
      "text": "Review Pane Is Git\nThe review pane reflects the state of the repository, not\nonly Codex edits. It can show Codex changes, your own\nuncommitted changes, and other repo changes.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-77359b05ffde",
