      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Stage Is Not Pre-Edit Approval\nCodex does not wait for you before editing files in the\napp. Staging happens after the edits exist.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-0d3f6e478b09",
      "originalText": "Stage Is Not Pre-Edit Approval\nCodex does not wait for you before editing files in the app. Staging happens after the edits exist.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "stage-is-not-pre-edit-approval"
      }
