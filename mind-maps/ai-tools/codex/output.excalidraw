      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Comment: Review Happens After Edits\nCodex edits first and asks for judgement\nlater. Treat the app like a Git-centered\nreview workflow, not an IDE suggestion\nflow that waits for approval before every\nchange.",
      "fontSize": 36,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 45.0,
      "containerId": "node-0a78366fe834",
      "originalText": "Comment: Review Happens After Edits\nCodex edits first and asks for judgement later. Treat the app like a Git-centered review workflow, not an IDE suggestion flow that waits for approval before every change.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "review-happens-after-edits"
      }
    },
