      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Control Moves After Execution\nThe app is not built around per-keystroke\napproval. Your main approval point is post-hoc\nreview of the diff and evidence.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-2c708952f668",
      "originalText": "Control Moves After Execution\nThe app is not built around per-keystroke approval. Your main approval point is post-hoc review of the diff and evidence.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "control-after-execution"
      }
    },
