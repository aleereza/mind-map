      "updated": 1775887291264,
      "link": null,
      "locked": false,
      "text": "Mental Model\nCodex is best understood as a task agent\nyou supervise, not as an autocomplete\nsystem you approve line by line.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-ba677ce51a4c",
      "originalText": "Mental Model\nCodex is best understood as a task agent you supervise, not as an autocomplete system you approve line by line.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "mental-model"
      },
      "index": "a5"
