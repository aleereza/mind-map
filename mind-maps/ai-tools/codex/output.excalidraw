      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Thread Means One Ongoing Task\nA thread contains your prompts plus Codex's\ntool calls and outputs. You can continue the\nsame thread with follow-up prompts instead\nof starting over.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-b162424aecfa",
      "originalText": "Thread Means One Ongoing Task\nA thread contains your prompts plus Codex's tool calls and outputs. You can continue the same thread with follow-up prompts instead of starting over.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "thread-means-task"
      }
