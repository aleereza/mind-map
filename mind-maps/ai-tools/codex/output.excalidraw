      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Inline Comments\nUse inline comments on specific diff lines\nwhen the output is close but not quite right.\nThis is often faster than rewriting the whole\ntask.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-2fcabf45d1cc",
      "originalText": "Inline Comments\nUse inline comments on specific diff lines when the output is close but not quite right. This is often faster than rewriting the whole task.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "inline-comments"
      }
    },
