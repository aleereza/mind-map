      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Codex App For Parallel Delegation\nThe desktop app is a command center for\nmultiple long-running tasks and background\nwork. It is best when you want to\nsupervise agents, not watch every edit\nlive.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-c3848123fb12",
      "originalText": "Codex App For Parallel Delegation\nThe desktop app is a command center for multiple long-running tasks and background work. It is best when you want to supervise agents, not watch every edit live.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "app-for-delegation"
      }
    },
