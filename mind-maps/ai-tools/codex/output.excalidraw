      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Start From A Clean Checkpoint\nBefore bigger Codex tasks, commit or stash\nyour current work so the review diff stays\nclean and easy to reason about.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-5ab53c9a5a83",
      "originalText": "Start From A Clean Checkpoint\nBefore bigger Codex tasks, commit or stash your current work so the review diff stays clean and easy to reason about.",
