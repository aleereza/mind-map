      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Commit Is The Acceptance Boundary\nA commit is the durable checkpoint that says\n\"this curated subset is accepted.\" Think of\nstaging as selection and commit as acceptance.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-9e9f12423aac",
      "originalText": "Commit Is The Acceptance Boundary\nA commit is the durable checkpoint that says \"this curated subset is accepted.\" Think of staging as selection and commit as acceptance.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "commit-acceptance-boundary"
      }
    },
