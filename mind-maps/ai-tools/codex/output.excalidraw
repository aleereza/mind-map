      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Review Pane\nThe review pane is a Git diff surface. It only\nworks inside a Git repo, and it is where you\ninspect diffs, open files in your editor, and\nshape what stays.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-e1e64d85f086",
      "originalText": "Review Pane\nThe review pane is a Git diff surface. It only works inside a Git repo, and it is where you inspect diffs, open files in your editor, and shape what stays.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "review-pane"
      }
    },
