      "updated": 1776217179223,
      "link": null,
      "locked": false,
      "text": "Stage Is Not Pre-Edit Approval\nCodex does not wait for you before editing files in the\napp. Staging happens after the edits exist.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
