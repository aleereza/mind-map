      "updated": 1776217179223,
      "link": null,
      "locked": false,
      "text": "IDE Approval Loop\nIn a traditional IDE flow, you inspect suggestions\nbefore they become part of the working copy.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-b33609a0e25c",
      "originalText": "IDE Approval Loop\nIn a traditional IDE flow, you inspect suggestions before they become part of the working copy.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "ide-approval-loop"
      },
      "index": "a7"
