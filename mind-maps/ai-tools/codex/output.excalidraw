      "strokeColor": "#57534E",
      "backgroundColor": "transparent",
      "width": 344.21435546875,
      "height": 65,
      "seed": 745706,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1776217179223,
      "link": null,
      "locked": false,
      "text": "Comment: Review Happens After Edits\nCodex edits first and asks for judgement later. Treat the app\nlike a Git-centered review workflow, not an IDE suggestion\nflow that waits for approval before every change.",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 16.25,
      "containerId": "node-0a78366fe834",
      "originalText": "Comment: Review Happens After Edits\nCodex edits first and asks for judgement later. Treat the app like a Git-centered review workflow, not an IDE suggestion flow that waits for approval before every change.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "review-happens-after-edits"
      },
      "index": "a3"
    },
