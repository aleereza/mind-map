      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Review Pane Mirrors Repo State\nThe review pane shows the Git state of\nthe repo, not only Codex edits. It can\nshow uncommitted changes, all branch\nchanges, last-turn changes, and staged or\nunstaged views.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
