      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Agent Review Loop\nIn Codex, the unit of work is a task thread.\nYou prompt, Codex works, then you inspect\nthe result and decide whether to iterate,\nstage, revert, or commit.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-2749f204a807",
      "originalText": "Agent Review Loop\nIn Codex, the unit of work is a task thread. You prompt, Codex works, then you inspect the result and decide whether to iterate, stage, revert, or commit.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "agent-review-loop"
      }
    },
