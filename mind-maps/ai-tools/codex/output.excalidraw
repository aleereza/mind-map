      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Traditional IDE Loop\nIn an IDE or copilot flow, the editor is\nprimary and you accept or reject suggestions\nbefore they become real changes.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-c463dbb3ada9",
      "originalText": "Traditional IDE Loop\nIn an IDE or copilot flow, the editor is primary and you accept or reject suggestions before they become real changes.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "traditional-ide-loop"
      }
    },
