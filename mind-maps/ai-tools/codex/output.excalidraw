      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Waiting To Approve Every Edit\nIf you expect Codex to pause on each file edit, the\napp will feel wrong. The intended loop is delegate\nfirst, review second.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-bbd41d44be1b",
      "originalText": "Waiting To Approve Every Edit\nIf you expect Codex to pause on each file edit, the app will feel wrong. The intended loop is delegate first, review second.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "waiting-to-approve"
      }
    },
