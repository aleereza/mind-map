      "text": "Mental Model Shift\nThe biggest change from\ntraditional IDEs is where control\nlives.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-ee97ee09a9a3",
      "originalText": "Mental Model Shift\nThe biggest change from traditional IDEs is where control lives.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "mental-model-shift"
      }
