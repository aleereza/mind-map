      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Use The Surface That Matches Risk\nUse the app when delegation speed matters, the\nCLI when approval control matters, and the IDE\nwhen close reading or surgical edits matter.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-979340123c7f",
      "originalText": "Use The Surface That Matches Risk\nUse the app when delegation speed matters, the CLI when approval control matters, and the IDE when close reading or surgical edits matter.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "surface-matches-risk"
      }
    },
