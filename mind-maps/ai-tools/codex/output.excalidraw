      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Plan First For Ambiguous Work\nFor complex tasks, use Plan mode or ask Codex\nto interview you first. Planning reduces\nwasted edits and makes later review simpler.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-5383c7cbb7e5",
