      "link": null,
      "locked": false,
      "text": "Codex Review Loop\nIn Codex, you assign a task, let the agent work, then\ninspect the resulting diff and evidence before\ndeciding what to keep.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-4376a6d23f43",
      "originalText": "Codex Review Loop\nIn Codex, you assign a task, let the agent work, then inspect the resulting diff and evidence before deciding what to keep.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "codex-review-loop"
      },
      "index": "a9"
