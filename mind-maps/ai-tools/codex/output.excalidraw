      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Partial Staging Is Normal\nThe same file can appear in both staged and unstaged\nviews. OpenAI's review docs call out that this is\nnormal Git behavior, not a Codex bug.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-43260e2c6323",
      "originalText": "Partial Staging Is Normal\nThe same file can appear in both staged and unstaged views. OpenAI's review docs call out that this is normal Git behavior, not a Codex bug.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "partial-staging"
      }
    },
