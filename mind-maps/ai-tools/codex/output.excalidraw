      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Mental Model\nCodex is best understood as a task\nagent you supervise, not as an\nautocomplete system you approve line\nby line.",
      "fontSize": 36,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 45.0,
      "containerId": "node-ba677ce51a4c",
      "originalText": "Mental Model\nCodex is best understood as a task agent you supervise, not as an autocomplete system you approve line by line.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "mental-model"
      }
    },
