      "link": null,
      "locked": false,
      "text": "CLI For Approval Gates\nUse the CLI when you want stronger approval control. In\nRead-only mode, Codex will not edit files or run\ncommands until you approve a plan.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
