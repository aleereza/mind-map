      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Should You Stage Every Change\nNo. Stage whatever you want in the next commit. If\nthe whole diff is good, stage all once and commit. If\nthe diff is mixed, stage only the good hunks or files\nand revert the rest.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-26e48fec8ff7",
      "originalText": "Should You Stage Every Change\nNo. Stage whatever you want in the next commit. If the whole diff is good, stage all once and commit. If the diff is mixed, stage only the good hunks or files and revert the rest.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "should-you-stage-everything"
      }
    },
