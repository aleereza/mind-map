      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Data Skew and Explosions\nSkew shows up when a small part of the data\ndrives most of the work, while row\nexplosions usually come from many-to-many\njoins or incomplete join predicates.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-e82241303ae6",
      "originalText": "Data Skew and Explosions\nSkew shows up when a small part of the data drives most of the work, while row explosions usually come from many-to-many joins or incomplete join predicates.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-data-skew-explosions"
      }
    },
