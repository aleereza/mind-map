      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Cost vs Runtime\nFast queries can still be expensive if they\nscan too much data, and slow queries can still\nbe cheap if they mostly wait in queue, so\ntrack cost and time separately.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-2fafc4b0ca07",
      "originalText": "Cost vs Runtime\nFast queries can still be expensive if they scan too much data, and slow queries can still be cheap if they mostly wait in queue, so track cost and time separately.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-cost-vs-runtime"
      }
    },
