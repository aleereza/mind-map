      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Query Identity\nThe minimum identity set is query_id, query\ntext, user, role, warehouse, start time, and\nquery hash so you can correlate the same\nstatement across profile views, history\ntables, grouped history, and dbt runs.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-1bf3bff3b781",
      "originalText": "Query Identity\nThe minimum identity set is query_id, query text, user, role, warehouse, start time, and query hash so you can correlate the same statement across profile views, history tables, grouped history, and dbt runs.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-query-identity"
      }
    },
