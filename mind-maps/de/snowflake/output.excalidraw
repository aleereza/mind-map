      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Cache Usage\nBytes served from cache can make repeat\nexecutions look cheap and fast, so compare\ncold-run behavior before claiming a model is\nwell optimized.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-0d69404ad622",
      "originalText": "Cache Usage\nBytes served from cache can make repeat executions look cheap and fast, so compare cold-run behavior before claiming a model is well optimized.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-cache-usage"
      }
