      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Core Metrics\nThese are the first facts to\ncapture before debating fixes.\nThey tell you whether the query is\nexpensive because it reads too\nmuch data, waits too long, or does\ntoo much work after scanning.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-0074ee912b9f",
      "originalText": "Core Metrics\nThese are the first facts to capture before debating fixes. They tell you whether the query is expensive because it reads too much data, waits too long, or does too much work after scanning.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-core-metrics"
      }
