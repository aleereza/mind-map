      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Query History Views\nSnowflake history table functions cover recent\nactivity and the Account Usage `QUERY_HISTORY`\nview extends analysis to longer windows, so\nyou can analyze query_id, warehouse, timing,\nscan volume, and credits in SQL instead of\nonly in the UI.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-f53f682e4ec4",
      "originalText": "Query History Views\nSnowflake history table functions cover recent activity and the Account Usage `QUERY_HISTORY` view extends analysis to longer windows, so you can analyze query_id, warehouse, timing, scan volume, and credits in SQL instead of only in the UI.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-query-history-views"
      }
    },
