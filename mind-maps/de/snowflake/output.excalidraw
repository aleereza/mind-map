      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Snowflake Query Profiling\nHigh-level map for reading\nSnowflake query performance,\ncapturing the metrics that matter,\nand linking slow queries back to a\ndbt project.\ncheckout this youtube video:\n[Snowflake Query Profiling Guide](\nhttps://www.youtube.com/watch?v=dQ\nw4w9WgXcQ)",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-544799ae1ba9",
      "originalText": "Snowflake Query Profiling\nHigh-level map for reading Snowflake query performance, capturing the metrics that matter, and linking slow queries back to a dbt project.\ncheckout this youtube video: [Snowflake Query Profiling Guide](https://www.youtube.com/watch?v=dQw4w9WgXcQ)",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-query-profiling"
      }
    },
