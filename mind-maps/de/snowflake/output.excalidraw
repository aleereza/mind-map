      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Manifest and Lineage\n`manifest.json` tells you which file owns the\nmodel, what it depends on, and which\ndownstream models are affected if you change\nthe SQL shape, using keys such as `nodes`,\n`parent_map`, and `child_map`.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-ae713b265082",
      "originalText": "Manifest and Lineage\n`manifest.json` tells you which file owns the model, what it depends on, and which downstream models are affected if you change the SQL shape, using keys such as `nodes`, `parent_map`, and `child_map`.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-dbt-manifest-lineage"
      }
    },
