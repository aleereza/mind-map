      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Reading A Slow Query\nRead the profile from the\nbottleneck outward. Find the\nexpensive node first, then inspect\nthe SQL shape that fed it.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-393bf70b466d",
      "originalText": "Reading A Slow Query\nRead the profile from the bottleneck outward. Find the expensive node first, then inspect the SQL shape that fed it.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-reading-a-slow-query"
      }
    },
