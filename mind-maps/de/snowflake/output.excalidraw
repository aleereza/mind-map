      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Run Results and Artifacts\n`run_results.json` gives execution status,\n`unique_id`, `execution_time`, timing steps,\n`adapter_response`, `compiled_code`, and\n`relation_name` so you can compare Snowflake runtime\nsignals with the model-level timing seen by dbt.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-1943cda128fd",
      "originalText": "Run Results and Artifacts\n`run_results.json` gives execution status, `unique_id`, `execution_time`, timing steps, `adapter_response`, `compiled_code`, and `relation_name` so you can compare Snowflake runtime signals with the model-level timing seen by dbt.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-dbt-run-results"
      }
    },
