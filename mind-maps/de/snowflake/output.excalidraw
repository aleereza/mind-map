      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Pattern-Level Views\nGrouped history by query hash or parameterized query\nhash helps separate a one-off incident from a\nrepeated pattern that deserves a dbt or warehouse\nchange.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-bb7de4151d07",
      "originalText": "Pattern-Level Views\nGrouped history by query hash or parameterized query hash helps separate a one-off incident from a repeated pattern that deserves a dbt or warehouse change.",
