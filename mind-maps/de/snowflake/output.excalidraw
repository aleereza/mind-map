      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Snowsight Query History\nSnowsight Query History is the fastest entry\npoint for recent troubleshooting because it\nshows query text, status, runtime,\nwarehouse, user, and a direct link into the\nprofile.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-19a089797b19",
      "originalText": "Snowsight Query History\nSnowsight Query History is the fastest entry point for recent troubleshooting because it shows query text, status, runtime, warehouse, user, and a direct link into the profile.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-snowsight-query-history"
      }
    },
