      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Query Profile Graph\nThe Query Profile graph shows the\nexecution plan as operators and steps so\nyou can see where time, scan volume,\nspill, and skew concentrate.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-3843d2abd8c0",
      "originalText": "Query Profile Graph\nThe Query Profile graph shows the execution plan as operators and steps so you can see where time, scan volume, spill, and skew concentrate.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-query-profile-graph"
      }
    },
