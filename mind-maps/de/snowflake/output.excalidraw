      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Queue and Compile Time\nHigh `queued_provisioning_time`,\n`queued_repair_time`, or `compilation_time` points to\nwarehouse pressure, concurrency, or plan complexity\nrather than to raw table scan volume.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-85dc595e76c9",
      "originalText": "Queue and Compile Time\nHigh `queued_provisioning_time`, `queued_repair_time`, or `compilation_time` points to warehouse pressure, concurrency, or plan complexity rather than to raw table scan volume.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-queue-compile-time"
      }
    },
