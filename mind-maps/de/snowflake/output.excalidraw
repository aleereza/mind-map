      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Partition Pruning\nThe ratio between `partitions_scanned` and\n`partitions_total` shows whether predicates\nnarrowed the read set or forced a broad\ntable scan.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-61b215d34df4",
      "originalText": "Partition Pruning\nThe ratio between `partitions_scanned` and `partitions_total` shows whether predicates narrowed the read set or forced a broad table scan.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-partition-pruning"
      }
    },
