      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Where To Look\nStart with the place that\nidentifies the query, then move\ninto the profile and history views\nthat explain why it was slow or\nexpensive.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-8fb6c19da12f",
      "originalText": "Where To Look\nStart with the place that identifies the query, then move into the profile and history views that explain why it was slow or expensive.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-where-to-look"
      }
    },
