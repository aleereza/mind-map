      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Warehouse Context\nWarehouse size, multi-cluster behavior, and\nconcurrent workload determine whether the same\nSQL spends time computing or simply waiting\nfor usable resources.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-cfd4c3be7579",
      "originalText": "Warehouse Context\nWarehouse size, multi-cluster behavior, and concurrent workload determine whether the same SQL spends time computing or simply waiting for usable resources.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-warehouse-context"
      }
    },
