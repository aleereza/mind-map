      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "GB Scanned\nGB scanned is the headline measure of how much\ndata Snowflake had to read, usually derived\nfrom bytes scanned and best interpreted\ntogether with pruning and cache signals.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-fa8c368416fe",
      "originalText": "GB Scanned\nGB scanned is the headline measure of how much data Snowflake had to read, usually derived from bytes scanned and best interpreted together with pruning and cache signals.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-gb-scanned"
      }
    },
