      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Total Time\nTotal elapsed time tells you what the user\nfelt, but it only becomes actionable after you\nsplit it into queueing, compilation,\nexecution, and post-processing time.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-0449cac7361c",
      "originalText": "Total Time\nTotal elapsed time tells you what the user felt, but it only becomes actionable after you split it into queueing, compilation, execution, and post-processing time.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-total-time"
      }
    },
