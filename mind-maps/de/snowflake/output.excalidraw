      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Query Tags\nIf your execution flow sets Snowflake `QUERY_TAG`, it\nbecomes a durable join key for grouping related dbt\nstatements by environment, job, or model family.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-2038757b6d89",
      "originalText": "Query Tags\nIf your execution flow sets Snowflake `QUERY_TAG`, it becomes a durable join key for grouping related dbt statements by environment, job, or model family.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sf-query-tags"
      }
    },
