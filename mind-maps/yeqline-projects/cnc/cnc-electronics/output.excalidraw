      "text": "Controller Limits\nFluidNC is not a safety PLC or a high-end\nfieldbus servo CNC; safety and high-power\nfault handling need external rated hardware.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-9d99db2781b8",
      "originalText": "Controller Limits\nFluidNC is not a safety PLC or a high-end fieldbus servo CNC; safety and high-power fault handling need external rated hardware.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "controller-limits"
      }
    },
