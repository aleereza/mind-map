      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Drive Boundary\nThe drive owns power electronics, current control,\nmotor feedback handling, protection, and local faults.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-10370aaf0e6a",
      "originalText": "Drive Boundary\nThe drive owns power electronics, current control, motor feedback handling, protection, and local faults.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "drive-boundary"
      }
    },
    {
      "type": "rectangle",
      "version": 1,
      "versionNonce": 5968247481,
      "isDeleted": false,
      "id": "node-e3078bf90fd5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 2428.6719380398245,
      "y": 881.2866980936625,
      "strokeColor": "#57534E",
      "backgroundColor": "#FAF7F2",
      "width": 423.7632905725852,
      "height": 299.53919487109243,
      "seed": 566617,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3,
        "value": 12
      },
      "boundElements": [
