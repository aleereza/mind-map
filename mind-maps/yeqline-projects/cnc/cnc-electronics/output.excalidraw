      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Safety Boundary\nSafety hardware should be able to remove or limit\nhazardous motion without trusting the G-code\n(machine tool programming commands) sender or\nfirmware.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-96c6a992004b",
      "originalText": "Safety Boundary\nSafety hardware should be able to remove or limit hazardous motion without trusting the G-code (machine tool programming commands) sender or firmware.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "safety-boundary"
      }
    },
    {
      "type": "rectangle",
      "version": 1,
      "versionNonce": 3990008323,
      "isDeleted": false,
      "id": "node-ade8c916c239",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 2422.2504352899655,
      "y": 1252.6330660192225,
      "strokeColor": "#57534E",
      "backgroundColor": "#FAF7F2",
      "width": 466.08663410485286,
      "height": 335.0,
      "seed": 670956,
