      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Controller Layer\nThe CNC (Computer Numerical\nControl) controller is the\nmachine-level decision maker. It\ndecides what motion should happen,\nnot how motor current is switched.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-7ef950708a9b",
      "originalText": "Controller Layer\nThe CNC (Computer Numerical Control) controller is the machine-level decision maker. It decides what motion should happen, not how motor current is switched.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "controller-layer"
      }
    },
