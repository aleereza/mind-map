      "text": "Drive Core Job\nA motor driver or drive translates\ncontroller commands into controlled voltage\nand current while protecting itself, the\nmotor, and sometimes the load.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-13ce43e43772",
      "originalText": "Drive Core Job\nA motor driver or drive translates controller commands into controlled voltage and current while protecting itself, the motor, and sometimes the load.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "drive-core-job"
      }
    },
