      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-e244d468eff2",
      "originalText": "True Servos\nTrue servo systems are designed around continuous feedback control, higher speeds, better inertia matching, and tighter following-error management.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "true-servos"
      }
