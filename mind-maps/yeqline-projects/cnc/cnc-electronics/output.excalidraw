      "text": "Drive Layer\nThe drive is the power electronics\nand control layer between\nlow-energy commands and\nhigh-energy motor windings.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-fcf7a0e4a660",
      "originalText": "Drive Layer\nThe drive is the power electronics and control layer between low-energy commands and high-energy motor windings.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "drive-layer"
      }
    },
