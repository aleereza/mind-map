      "locked": false,
      "text": "Timestamped Feedback\nHigh-end systems timestamp I/O and feedback so\nmeasurements can be correlated with motion instead of\nguessed afterward.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-f32956fa4e1c",
      "originalText": "Timestamped Feedback\nHigh-end systems timestamp I/O and feedback so measurements can be correlated with motion instead of guessed afterward.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "timestamped-feedback"
      }
    },
