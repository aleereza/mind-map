      "updated": 1,
      "link": null,
      "locked": false,
      "text": "STO (Safe Torque Off) And SS1 (Safe Stop 1)\nSafe Torque Off prevents torque-producing\noutput, while Safe Stop 1 stops first and then\nremoves torque.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-0799e67cd4a6",
      "originalText": "STO (Safe Torque Off) And SS1 (Safe Stop 1)\nSafe Torque Off prevents torque-producing output, while Safe Stop 1 stops first and then removes torque.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "sto-and-ss1"
      }
    },
