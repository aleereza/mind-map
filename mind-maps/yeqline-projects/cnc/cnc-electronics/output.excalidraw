      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Energy Control\nTypical outputs remove or limit torque through\nSTO (Safe Torque Off), drop motor or spindle\ncontactors, disable process energy, close\nvalves, or command a controlled safe stop.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-ce56fb79136a",
      "originalText": "Energy Control\nTypical outputs remove or limit torque through STO (Safe Torque Off), drop motor or spindle contactors, disable process energy, close valves, or command a controlled safe stop.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "energy-control"
      }
    },
