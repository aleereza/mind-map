      "text": "Inductance Limit\nStepper windings resist rapid current change, so high\nspeed requires enough bus voltage and a driver that\ncan force current quickly.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-3860001407ae",
      "originalText": "Inductance Limit\nStepper windings resist rapid current change, so high speed requires enough bus voltage and a driver that can force current quickly.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "inductance-limit"
      }
    },
