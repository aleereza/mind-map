      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "System Mental Model\nThink in four simultaneous paths:\ncommands tell the machine what to\ndo, power lets it do work,\nfeedback says what happened, and\nsafety limits what is allowed.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-4ddaabdd40cc",
      "originalText": "System Mental Model\nThink in four simultaneous paths: commands tell the machine what to do, power lets it do work, feedback says what happened, and safety limits what is allowed.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "system-mental-model"
      }
    },
