      "text": "Motor Phase Current\nTorque comes from controlled winding\ncurrent, not from the step pulse itself; the\npulse is only a command.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-cb9115171ad9",
      "originalText": "Motor Phase Current\nTorque comes from controlled winding current, not from the step pulse itself; the pulse is only a command.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "motor-phase-current"
      }
    },
