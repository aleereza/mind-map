      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Controller Layer\nThe controller owns the\nmachine-level intent: coordinate\nsystems, trajectory planning,\ntiming, I/O logic, alarms, homing,\nprobing, and job execution.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-7ef950708a9b",
      "originalText": "Controller Layer\nThe controller owns the machine-level intent: coordinate systems, trajectory planning, timing, I/O logic, alarms, homing, probing, and job execution.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "controller-layer"
      }
    },
