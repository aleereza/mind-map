      "text": "Safety Path\nSafety hardware watches for conditions where motion or\nprocess energy must stop, then permits, removes, or limits\nhazardous energy without depending on the normal controller.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-6bba4c97fcdf",
      "originalText": "Safety Path\nSafety hardware watches for conditions where motion or process energy must stop, then permits, removes, or limits hazardous energy without depending on the normal controller.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "safety-path"
      }
    },
