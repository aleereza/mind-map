      "text": "High Level System Model\nUnderstand the machine as four\npaths that meet at each axis:\ncommand, power, feedback, and\nsafety.",
      "fontSize": 36,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 45.0,
      "containerId": "node-e033e8593813",
      "originalText": "High Level System Model\nUnderstand the machine as four paths that meet at each axis: command, power, feedback, and safety.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "whole-system-model"
      }
    },
