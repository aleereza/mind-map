      "text": "Safety Upgrade\nA safety upgrade adds risk assessment, safety relay\nor safety PLC, STO wiring, guard interlocks,\nvalidation, and documented reset behavior.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-7805d1455c9c",
      "originalText": "Safety Upgrade\nA safety upgrade adds risk assessment, safety relay or safety PLC, STO wiring, guard interlocks, validation, and documented reset behavior.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "safety-upgrade"
      }
    },
