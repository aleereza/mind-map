      "updated": 1,
      "link": null,
      "locked": false,
      "text": "FluidNC Controller\nIn the example, FluidNC is the 6-axis motion\ncontroller that maps axes to motor outputs and\nsends step, direction, and enable signals to\nexternal closed-loop stepper drives.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-50aefb08b9ae",
      "originalText": "FluidNC Controller\nIn the example, FluidNC is the 6-axis motion controller that maps axes to motor outputs and sends step, direction, and enable signals to external closed-loop stepper drives.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "fluidnc-controller"
      }
    },
