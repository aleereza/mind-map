      "link": null,
      "locked": false,
      "text": "Controller Limit\nFluidNC is not a safety PLC (Programmable\nLogic Controller) or a high-end fieldbus CNC\n(Computer Numerical Control system).\nDangerous energy needs external rated\nhardware.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-438f66606b13",
      "originalText": "Controller Limit\nFluidNC is not a safety PLC (Programmable Logic Controller) or a high-end fieldbus CNC (Computer Numerical Control system). Dangerous energy needs external rated hardware.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "controller-limit"
      }
    },
