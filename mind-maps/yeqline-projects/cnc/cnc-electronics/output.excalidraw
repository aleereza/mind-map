      "locked": false,
      "text": "Closed-Loop Steppers\nClosed-loop steppers keep stepper mechanics\nand step/dir control while adding\nencoder-based correction, stall alarms, and\nbetter low-speed behavior.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-ddaee44826c7",
      "originalText": "Closed-Loop Steppers\nClosed-loop steppers keep stepper mechanics and step/dir control while adding encoder-based correction, stall alarms, and better low-speed behavior.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "closed-loop-steppers"
      }
