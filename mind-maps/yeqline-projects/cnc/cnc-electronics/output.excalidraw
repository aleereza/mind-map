      "locked": false,
      "text": "Gantry Fault Case\nIf one Y drive faults while the other\ncontinues, the gantry can rack hard; fault\noutputs should stop all coordinated\nmotion.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-626c4883b063",
      "originalText": "Gantry Fault Case\nIf one Y drive faults while the other continues, the gantry can rack hard; fault outputs should stop all coordinated motion.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "gantry-fault-case"
      }
    },
