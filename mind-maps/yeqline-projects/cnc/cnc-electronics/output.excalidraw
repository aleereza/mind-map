      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Example Axis Mapping\nMap one motor to X, one motor to Z, and\ntwo motors to Y so the gantry can square\nduring homing and move as one coordinated\nY axis during cutting.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-ba86f1241707",
      "originalText": "Example Axis Mapping\nMap one motor to X, one motor to Z, and two motors to Y so the gantry can square during homing and move as one coordinated Y axis during cutting.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "example-axis-mapping"
      }
    },
