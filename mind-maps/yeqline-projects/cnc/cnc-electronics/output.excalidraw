      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Open-Loop Steppers\nOpen-loop steppers are simple and\ndeterministic when torque margin is high, but\nmissed steps can go unnoticed until the part\nor machine reveals the error.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-6096cc25694b",
      "originalText": "Open-Loop Steppers\nOpen-loop steppers are simple and deterministic when torque margin is high, but missed steps can go unnoticed until the part or machine reveals the error.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "open-loop-steppers"
      }
