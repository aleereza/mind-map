      "locked": false,
      "text": "Motor Encoder\nMeasures motor shaft position and helps the drive\ncontrol rotor motion, but it cannot see belt stretch,\nscrew pitch error, backlash, or frame deflection.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-3edd25c91dfe",
      "originalText": "Motor Encoder\nMeasures motor shaft position and helps the drive control rotor motion, but it cannot see belt stretch, screw pitch error, backlash, or frame deflection.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "motor-encoder"
      }
    },
