      "width": 244.34375,
      "height": 70.0,
      "seed": 598344,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Controller Boundary\nThe controller owns trajectory planning,\nmachine state, I/O (Input/Output) logic,\nhoming, alarms, and command timing.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-5f694c0eeb13",
      "originalText": "Controller Boundary\nThe controller owns trajectory planning, machine state, I/O (Input/Output) logic, homing, alarms, and command timing.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "controller-boundary"
      }
    },
    {
      "type": "rectangle",
      "version": 1,
      "versionNonce": 2309540698,
      "isDeleted": false,
      "id": "node-1d9124d63f30",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 1959.0800360645578,
      "y": 685.5096582662733,
      "strokeColor": "#57534E",
      "backgroundColor": "#FAF7F2",
      "width": 417.8,
      "height": 287.0,
      "seed": 766761,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3,
