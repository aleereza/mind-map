      "text": "Stop And Reset Behavior\nStop category 0 removes torque immediately;\nstop category 1 decelerates first; reset\nmust not automatically restart hazards.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-8216abe8c1ea",
      "originalText": "Stop And Reset Behavior\nStop category 0 removes torque immediately; stop category 1 decelerates first; reset must not automatically restart hazards.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "stop-and-reset-behavior"
      }
    },
