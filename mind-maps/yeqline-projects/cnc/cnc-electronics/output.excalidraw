      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Upgrade Path\nThe example FluidNC machine can teach core CNC\nelectronics, while the industrial upgrade path\nreplaces step/dir timing with fieldbus drives,\nrated safety, and richer feedback.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-c0cee6dfc53a",
      "originalText": "Upgrade Path\nThe example FluidNC machine can teach core CNC electronics, while the industrial upgrade path replaces step/dir timing with fieldbus drives, rated safety, and richer feedback.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "upgrade-path"
      }
    },
