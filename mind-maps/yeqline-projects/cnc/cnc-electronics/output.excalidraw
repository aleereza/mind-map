      "text": "Squaring Homing\nIndependent Y home switches allow each side to\nreference separately before coordinated cutting,\nreducing gantry skew.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-4c18adc64b46",
