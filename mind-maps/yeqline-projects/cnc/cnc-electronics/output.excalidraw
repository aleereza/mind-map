      "text": "Command Path\nG-code or a higher-level job becomes\ncoordinated axis motion, then\nelectrical commands to each drive.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-3ba2dddee649",
      "originalText": "Command Path\nG-code or a higher-level job becomes coordinated axis motion, then electrical commands to each drive.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "command-path"
      }
