      "updated": 1,
      "link": null,
      "locked": false,
      "text": "System Boundaries\nGood designs keep controller decisions,\ndrive control, machine mechanics, and safety\nauthority separate.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-0633af256d90",
      "originalText": "System Boundaries\nGood designs keep controller decisions, drive control, machine mechanics, and safety authority separate.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "system-boundaries"
      }
    },
    {
