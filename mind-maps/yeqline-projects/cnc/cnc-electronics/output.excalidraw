      "updated": 1,
      "link": null,
      "locked": false,
      "text": "I/O And Safety\nMachine I/O tells the controller\nwhat the machine is allowed to do,\nwhile safety-rated hardware\ndecides what the machine is\nallowed to energize.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-b1c83a09ed43",
      "originalText": "I/O And Safety\nMachine I/O tells the controller what the machine is allowed to do, while safety-rated hardware decides what the machine is allowed to energize.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "io-and-safety"
      }
    },
