      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Safety Decision\nA safety relay, safety PLC (Programmable\nLogic Controller), or rated drive\nfunction checks the input circuit, reset\ncondition, and feedback contacts before\nallowing hazardous outputs.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-89559c5486d6",
      "originalText": "Safety Decision\nA safety relay, safety PLC (Programmable Logic Controller), or rated drive function checks the input circuit, reset condition, and feedback contacts before allowing hazardous outputs.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "safety-decision"
      }
    },
