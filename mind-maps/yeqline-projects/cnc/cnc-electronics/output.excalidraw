      "text": "Drive Loop\nClosed-loop stepper drives usually close the\nloop at the motor, so they do not see screw\nerror or gantry skew.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-b49f889a8cc0",
      "originalText": "Drive Loop\nClosed-loop stepper drives usually close the loop at the motor, so they do not see screw error or gantry skew.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "drive-loop"
      }
    },
