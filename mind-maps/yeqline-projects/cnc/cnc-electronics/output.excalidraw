      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Grbl-Style Workflow\nFluidNC keeps the familiar sender, G-code,\nalarm, homing, and work-coordinate workflow\nwhile moving configuration into machine-readable\nfiles.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-4009ee073e5f",
      "originalText": "Grbl-Style Workflow\nFluidNC keeps the familiar sender, G-code, alarm, homing, and work-coordinate workflow while moving configuration into machine-readable files.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "grbl-style-workflow"
      }
    },
