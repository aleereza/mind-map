      "locked": false,
      "text": "Six Axis Capacity\nThe six motion channels can cover X, dual Y motors,\nZ, and still leave channels for rotary, tangential,\nor future machine expansion.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-b489ad7f73f8",
      "originalText": "Six Axis Capacity\nThe six motion channels can cover X, dual Y motors, Z, and still leave channels for rotary, tangential, or future machine expansion.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "six-axis-capacity"
      }
    },
