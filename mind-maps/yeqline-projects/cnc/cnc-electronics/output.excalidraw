      "text": "PC Parallel Port\nOlder PC-based controllers generated real-time step\npulses directly from a parallel port, but timing\ndepends heavily on the host and OS.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-0092f94074d0",
      "originalText": "PC Parallel Port\nOlder PC-based controllers generated real-time step pulses directly from a parallel port, but timing depends heavily on the host and OS.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "pc-parallel-port"
      }
