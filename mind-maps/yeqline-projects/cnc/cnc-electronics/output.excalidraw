      "text": "Deterministic Timing\nCoordinated motion depends on bounded\nlatency and jitter because each axis command\nmust arrive at the right time relative to\nall others.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-3d88fe9272ce",
      "originalText": "Deterministic Timing\nCoordinated motion depends on bounded latency and jitter because each axis command must arrive at the right time relative to all others.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "deterministic-timing"
      }
    },
