      "text": "Drive Feedback\nClosed-loop stepper and servo drives use motor\nencoders to regulate current, speed, position, or\nstall recovery.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-6a9504f9b592",
      "originalText": "Drive Feedback\nClosed-loop stepper and servo drives use motor encoders to regulate current, speed, position, or stall recovery.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "drive-feedback"
      }
    },
