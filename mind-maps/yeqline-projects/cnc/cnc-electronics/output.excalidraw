      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Drive-Motor Layer\nThe drive-motor layer turns\ncommand timing into torque. This\nis where power electronics, motor\nphysics, feedback, and protection\nmeet.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-e84666810239",
      "originalText": "Drive-Motor Layer\nThe drive-motor layer turns command timing into torque. This is where power electronics, motor physics, feedback, and protection meet.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "drive-motor-layer"
      }
