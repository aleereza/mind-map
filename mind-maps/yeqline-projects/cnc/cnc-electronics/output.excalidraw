      "locked": false,
      "text": "Loop Ownership\nThe drive may own only current control, or it may\nalso own velocity and position loops in servo and\nclosed-loop stepper systems.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-84e585dbfb67",
      "originalText": "Loop Ownership\nThe drive may own only current control, or it may also own velocity and position loops in servo and closed-loop stepper systems.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "loop-ownership"
      }
    },
