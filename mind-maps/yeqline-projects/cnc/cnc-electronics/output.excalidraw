      "locked": false,
      "text": "CNC Electronics\nHow electrical power,\ndeterministic timing, feedback,\nand safety turn toolpath commands\ninto controlled machine motion.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 22.5,
      "containerId": "node-082c835b1693",
      "originalText": "CNC Electronics\nHow electrical power, deterministic timing, feedback, and safety turn toolpath commands into controlled machine motion.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "cnc-electronics"
      }
    },
