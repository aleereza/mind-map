      "text": "Hardwired Stop\nEmergency stop chains should not depend only on\nfirmware, USB, Wi-Fi, or the G-code sender.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15.0,
      "containerId": "node-31d706fe3bf6",
      "originalText": "Hardwired Stop\nEmergency stop chains should not depend only on firmware, USB, Wi-Fi, or the G-code sender.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "hardwired-stop"
      }
