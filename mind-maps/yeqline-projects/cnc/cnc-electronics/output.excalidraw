      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Restart Control\nAfter a safety trip, reset should prove\nthe hazard is cleared and require a\ndeliberate restart; releasing the E-stop\n(Emergency Stop) should not automatically\nresume motion.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-c2f714fd556c",
      "originalText": "Restart Control\nAfter a safety trip, reset should prove the hazard is cleared and require a deliberate restart; releasing the E-stop (Emergency Stop) should not automatically resume motion.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "restart-control"
      }
    },
