      "text": "Safety Path\nSafety is a separate permission system that\ncan remove torque, stop motion, or block\nrestart even if the controller software fails.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-6bba4c97fcdf",
      "originalText": "Safety Path\nSafety is a separate permission system that can remove torque, stop motion, or block restart even if the controller software fails.",
      "lineHeight": 1.25,
      "autoResize": true,
      "customData": {
        "node_id": "safety-path"
      }
    },
