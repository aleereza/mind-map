      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Hazard Inputs\nExamples include emergency-stop buttons,\nguard-door switches, hard limits, drive safety\nfeedback, spindle faults, air-pressure faults,\nand process interlocks.",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 17.5,
      "containerId": "node-b2a0bbee1c99",
